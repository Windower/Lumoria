{
  "id": "proton-cachyos",
  "name": "Proton-CachyOS",
  "wine_arch": "win64",
  "github_repo": "CachyOS/proton-cachyos",
  "version_dir": "cachyos-(.+)",
  "asset_regex": "proton-cachyos-.*-x86_64\\.tar\\.xz$",
  "checksum_regex": "proton-cachyos-.*-x86_64\\.sha512sum$",
  "support_files": [
    {
      "id": "icu-win32",
      "mode": "symlink",
      "files": ["icudt68.dll", "icuin68.dll", "icuuc68.dll"],
      "src_dirs": [
        "files/lib/wine/icu/i386-windows"
      ],
      "dst_dir": "drive_c/windows/system32",
      "when": { "ARCH": "win32" }
    },
    {
      "id": "icu-win64-x86",
      "mode": "symlink",
      "files": ["icudt68.dll", "icuin68.dll", "icuuc68.dll"],
      "src_dirs": [
        "files/lib/wine/icu/i386-windows"
      ],
      "dst_dir": "drive_c/windows/syswow64",
      "when": { "ARCH": "win64" }
    },
    {
      "id": "icu-win64-x64",
      "mode": "symlink",
      "files": ["icudt68.dll", "icuin68.dll", "icuuc68.dll"],
      "src_dirs": [
        "files/lib/wine/icu/x86_64-windows"
      ],
      "dst_dir": "drive_c/windows/system32",
      "when": { "ARCH": "win64" }
    }
  ],
  "variants": [
    {
      "id": "wow64",
      "label": "WoW64 (recommended)",
      "default": true,
      "wine_bin": "files/bin-wow64/wine",
      "wineserver": "files/bin-wow64/wineserver",
      "wine_bins": ["files/bin-wow64/wine", "files/bin/wine"],
      "wineservers": ["files/bin-wow64/wineserver", "files/bin/wineserver"],
      "binary_kind": "wow64",
      "sandbox_supported": true,
      "paths": {
        "bin": "files/bin-wow64",
        "bin_paths": ["files/bin-wow64", "files/bin"],
        "lib": ["files/lib"],
        "lib_32": ["files/lib/i386-linux-gnu"],
        "lib_64": ["files/lib/x86_64-linux-gnu"],
        "wine_dll": ["files/lib/wine", "files/lib/wine/i386-windows", "files/lib/wine/x86_64-windows", "files/lib/wine/icu/i386-windows", "files/lib/wine/icu/x86_64-windows", "files/lib/vkd3d", "files/lib/wine/vkd3d-proton", "files/lib/wine/dxvk", "files/lib/wine/nvapi"],
        "wine_unix": ["files/lib/wine/x86_64-unix", "files/lib/wine/i386-unix"]
      }
    },
    {
      "id": "bin",
      "label": "Legacy 32-bit binary",
      "wine_bin": "files/bin/wine",
      "wineserver": "files/bin/wineserver",
      "binary_kind": "legacy32",
      "wine_arch": "win32",
      "sandbox_supported": false,
      "paths": {
        "bin": "files/bin",
        "lib": ["files/lib"],
        "lib_32": ["files/lib/i386-linux-gnu"],
        "lib_64": ["files/lib/x86_64-linux-gnu"],
        "wine_dll": ["files/lib/wine", "files/lib/wine/i386-windows", "files/lib/wine/x86_64-windows", "files/lib/wine/icu/i386-windows", "files/lib/wine/icu/x86_64-windows", "files/lib/vkd3d", "files/lib/wine/vkd3d-proton", "files/lib/wine/dxvk", "files/lib/wine/nvapi"],
        "wine_unix": ["files/lib/wine/x86_64-unix", "files/lib/wine/i386-unix"]
      }
    }
  ]
}
