{
  "id": "dotnetdesktop8",
  "name": ".NET Desktop Runtime 8.0",
  "variables": {
    "DOTNET_X86_ROOT": {
      "default": "drive_c/Program Files/dotnet",
      "rules": [
        {
          "value": "drive_c/Program Files (x86)/dotnet",
          "when": {
            "var": {
              "ARCH": "win64"
            }
          }
        }
      ]
    },
    "DOTNET_X64_ROOT": "drive_c/Program Files/dotnet"
  },
  "downloads": [
    {
      "id": "dotnetdesktop8_x86",
      "url": "https://download.visualstudio.microsoft.com/download/pr/acf6e5d3-1e2f-4072-833c-fa84a10841c5/acd48342207247f404a5aaa58d1a1ea1/windowsdesktop-runtime-8.0.12-win-x86.exe",
      "dest": "${var.CACHE_REDIST}/dotnetdesktop8/windowsdesktop-runtime-8.0.12-win-x86.exe",
      "sha256": "340e30c8611af3800b74f0560f0b6f3feab82ee5cfa3fc0d115b84b08bd5456d"
    },
    {
      "id": "dotnetdesktop8_x64",
      "url": "https://download.visualstudio.microsoft.com/download/pr/f1e7ffc8-c278-4339-b460-517420724524/f36bb75b2e86a52338c4d3a90f8dac9b/windowsdesktop-runtime-8.0.12-win-x64.exe",
      "dest": "${var.CACHE_REDIST}/dotnetdesktop8/windowsdesktop-runtime-8.0.12-win-x64.exe",
      "sha256": "cb51b559f343cb56e23cad2e5af8c4d1701e221a0a2a4116193a2a9375568814",
      "when": {
        "var": {
          "ARCH": "win64"
        }
      }
    }
  ],
  "steps": [
    {
      "type": "wineexec",
      "description": "Install .NET Desktop Runtime 8.0 (x86)",
      "command": "${var.CACHE_REDIST}/dotnetdesktop8/windowsdesktop-runtime-8.0.12-win-x86.exe",
      "args": [
        "/quiet"
      ],
      "working_dir": "${var.CACHE_REDIST}/dotnetdesktop8",
      "verify_paths": [
        "${var.PREFIX}/${var.DOTNET_X86_ROOT}/dotnet.exe"
      ]
    },
    {
      "type": "wineexec",
      "description": "Install .NET Desktop Runtime 8.0 (x64)",
      "command": "${var.CACHE_REDIST}/dotnetdesktop8/windowsdesktop-runtime-8.0.12-win-x64.exe",
      "args": [
        "/quiet"
      ],
      "working_dir": "${var.CACHE_REDIST}/dotnetdesktop8",
      "verify_paths": [
        "${var.PREFIX}/${var.DOTNET_X64_ROOT}/dotnet.exe"
      ],
      "when": {
        "var": {
          "ARCH": "win64"
        }
      }
    }
  ]
}
