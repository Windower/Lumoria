{
  "id": "constantia",
  "name": "Constantia",
  "downloads": [
    {
      "id": "pptviewer",
      "url": "https://web.archive.org/web/20171225132744if_/https://download.microsoft.com/download/E/6/7/E675FFFC-2A6D-4AB0-B3EB-27C9F8C8F696/PowerPointViewer.exe",
      "dest": "${var.CACHE_REDIST}/pptfonts/PowerPointViewer.exe",
      "sha256": "249473568eba7a1e4f95498acba594e0f42e6581add4dead70c1dfb908a09423"
    }
  ],
  "steps": [
    {
      "type": "cabextract",
      "description": "Extract ppviewer.cab",
      "src": "${var.CACHE_REDIST}/pptfonts/PowerPointViewer.exe",
      "args": [
        "ppviewer.cab"
      ],
      "dst": "${var.CACHE_REDIST}/pptfonts/ppviewer.cab"
    },
    {
      "type": "fonts",
      "description": "Install Constantia",
      "dst": "${var.FONTS}",
      "args": [
        "${var.CACHE_REDIST}/pptfonts/ppviewer.cab"
      ],
      "font_registrations": [
        "constan.ttf|Constantia",
        "constanb.ttf|Constantia Bold",
        "constani.ttf|Constantia Italic",
        "constanz.ttf|Constantia Bold Italic"
      ],
      "when": {
        "not": {
          "file_exists": "${var.FONTS}/constan.ttf"
        }
      }
    }
  ]
}
