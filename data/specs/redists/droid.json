        "${CACHE_REDIST}/droid/DroidSerif-Italic.ttf",
        "${CACHE_REDIST}/droid/DroidSerif-Regular.ttf"
      ],
      "font_registrations": [
        "droidsans-bold.ttf|Droid Sans Bold",
        "droidsansfallback.ttf|Droid Sans Fallback",
        "droidsansjapanese.ttf|Droid Sans Japanese",
        "droidsansmono.ttf|Droid Sans Mono",
        "droidsans.ttf|Droid Sans",
        "droidserif-bolditalic.ttf|Droid Serif Bold Italic",
        "droidserif-bold.ttf|Droid Serif Bold",
        "droidserif-italic.ttf|Droid Serif Italic",
        "droidserif-regular.ttf|Droid Serif"
      ],
      "when": { "not": { "file_exists": "${FONTS}/droidsans.ttf" } }
    }
  ]
