{
  "id": "dotnet10",
  "name": ".NET Runtime 10.0",
  "variables": {
    "DOTNET_X86_ROOT": {
      "default": "drive_c/Program Files/dotnet",
      "rules": [
        {
          "value": "drive_c/Program Files (x86)/dotnet",
          "when": {
            "var": {
              "ARCH": "win64"
            }
          }
        }
      ]
    },
    "DOTNET_X64_ROOT": "drive_c/Program Files/dotnet"
  },
  "downloads": [
    {
      "id": "dotnet10_x86",
      "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/10.0.0/dotnet-runtime-10.0.0-win-x86.exe",
      "dest": "${var.CACHE_REDIST}/dotnet10/dotnet-runtime-10.0.0-win-x86.exe",
      "sha256": "90bc5667c2a35c030a2e964e7083fe8fbdbc461377d27b4f0d9bf7b400d7b982"
    },
    {
      "id": "dotnet10_x64",
      "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/10.0.0/dotnet-runtime-10.0.0-win-x64.exe",
      "dest": "${var.CACHE_REDIST}/dotnet10/dotnet-runtime-10.0.0-win-x64.exe",
      "sha256": "ca2dd25d477174767a55756d9ef92bbda0d3c7ef12cef284a542689b2ba52767",
      "when": {
        "var": {
          "ARCH": "win64"
        }
      }
    }
  ],
  "steps": [
    {
      "type": "wineexec",
      "description": "Install .NET Runtime 10.0 (x86)",
      "command": "${var.CACHE_REDIST}/dotnet10/dotnet-runtime-10.0.0-win-x86.exe",
      "args": [
        "/quiet"
      ],
      "working_dir": "${var.CACHE_REDIST}/dotnet10",
      "verify_paths": [
        "${var.PREFIX}/${var.DOTNET_X86_ROOT}/dotnet.exe"
      ]
    },
    {
      "type": "wineexec",
      "description": "Install .NET Runtime 10.0 (x64)",
      "command": "${var.CACHE_REDIST}/dotnet10/dotnet-runtime-10.0.0-win-x64.exe",
      "args": [
        "/quiet"
      ],
      "working_dir": "${var.CACHE_REDIST}/dotnet10",
      "verify_paths": [
        "${var.PREFIX}/${var.DOTNET_X64_ROOT}/dotnet.exe"
      ],
      "when": {
        "var": {
          "ARCH": "win64"
        }
      }
    }
  ]
}
