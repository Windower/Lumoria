{
  "id": "uff",
  "name": "Ubuntu Font Family",
  "downloads": [
    {
      "id": "uff_archive",
      "url": "https://assets.ubuntu.com/v1/fad7939b-ubuntu-font-family-0.83.zip",
      "dest": "${CACHE_REDIST}/uff/ubuntu-font-family-0.83.zip",
      "sha256": "456d7d42797febd0d7d4cf1b782a2e03680bb4a5ee43cc9d06bda172bac05b42"
    }
  ],
  "steps": [
    {
      "type": "fonts",
      "description": "Install Ubuntu Font Family",
      "dst": "${FONTS}",
      "args": ["${CACHE_REDIST}/uff/ubuntu-font-family-0.83.zip"],
      "font_registrations": [
        "ubuntu-r.ttf|Ubuntu",
        "ubuntu-b.ttf|Ubuntu Bold",
        "ubuntu-bi.ttf|Ubuntu Bold Italic",
        "ubuntu-i.ttf|Ubuntu Italic",
        "ubuntu-l.ttf|Ubuntu Light",
        "ubuntu-li.ttf|Ubuntu Light Italic",
        "ubuntu-m.ttf|Ubuntu Medium",
        "ubuntu-mi.ttf|Ubuntu Medium Italic",
        "ubuntu-c.ttf|Ubuntu Condensed",
        "ubuntumono-r.ttf|Ubuntu Mono",
        "ubuntumono-b.ttf|Ubuntu Mono Bold",
        "ubuntumono-bi.ttf|Ubuntu Mono Bold Italic",
        "ubuntumono-ri.ttf|Ubuntu Mono Italic"
      ],
      "when": { "not": { "file_exists": "${FONTS}/ubuntu-r.ttf" } }
    }
  ]
}
