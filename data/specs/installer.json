{
  "id": "ffxi",
  "name": "Final Fantasy XI",
  "version": "1.0",
  "variables": {
    "SE_DIR": "drive_c/Program Files (x86)/PlayOnline/SquareEnix",
    "WINE_USERPROFILE_HOST": "@winepath:%USERPROFILE%",
    "REGION": "@prefix:region"
  },
  "entrypoints": [
    {
      "id": "pol",
      "name": "PlayOnline Viewer",
      "exe": "${SE_DIR}/PlayOnlineViewer/pol.exe",
      "default": true
    },
    {
      "id": "pol-config",
      "name": "PlayOnline Config",
      "exe": "${SE_DIR}/PlayOnlineViewer/polcfg/polcfg.exe"
    },
    {
      "id": "ffxi-config",
      "name": "Final Fantasy XI Config",
      "exe": "${SE_DIR}/FINAL FANTASY XI/Tools${REGION:upper}/FINAL FANTASY XI Config.exe",
      "when": { "not": { "REGION": "jp" } }
    },
    {
      "id": "ffxi-config",
      "name": "Final Fantasy XI Config",
      "exe": "${SE_DIR}/FINAL FANTASY XI/Tools/FINAL FANTASY XI Config.exe",
      "when": { "REGION": "jp" }
    },
    {
      "id": "ffxi-padconfig",
      "name": "FFXI Gamepad Config",
      "exe": "${SE_DIR}/FINAL FANTASY XI/Tools${REGION:upper}/FFXiPadConfig.exe",
      "when": { "not": { "REGION": "jp" } }
    },
    {
      "id": "ffxi-padconfig",
      "name": "FFXI Gamepad Config",
      "exe": "${SE_DIR}/FINAL FANTASY XI/Tools/FFXiPadConfig.exe",
      "when": { "REGION": "jp" }
    }
  ],
  "redists": ["corefonts", "gdiplus"],
  "env": [
    {
      "vars": { "LANG": "ja_JP.UTF-8" },
      "when": { "REGION": "jp" }
    }
  ],
  "steps": [
    {
      "type": "dll_override",
      "description": "Disable mscoree when .NET is not installed",
      "command": "mscoree",
      "mode": "disabled",
      "when": { "not": { "REDIST_dotnet48": "1" } }
    },
    {
      "type": "link",
      "description": "Prepare installer archive links",
      "mode": "symlink",
      "dst": "${CACHE}",
      "args": [
        "${CACHE}/installer_part1/FFXIFullSetup_${REGION:upper}.part1.exe",
        "${CACHE}/installer_part2/FFXIFullSetup_${REGION:upper}.part2.rar",
        "${CACHE}/installer_part3/FFXIFullSetup_${REGION:upper}.part3.rar",
        "${CACHE}/installer_part4/FFXIFullSetup_${REGION:upper}.part4.rar",
        "${CACHE}/installer_part5/FFXIFullSetup_${REGION:upper}.part5.rar"
      ]
    },
    {
      "type": "extract_multi",
      "description": "Extract installer archive",
      "src": "${CACHE}/FFXIFullSetup_${REGION:upper}.part1.exe",
      "args": [
        "${CACHE}/FFXIFullSetup_${REGION:upper}.part2.rar",
        "${CACHE}/FFXIFullSetup_${REGION:upper}.part3.rar",
        "${CACHE}/FFXIFullSetup_${REGION:upper}.part4.rar",
        "${CACHE}/FFXIFullSetup_${REGION:upper}.part5.rar"
      ],
      "dst": "${CACHE}",
      "when": { "not": { "any": [
        { "file_exists": "${CACHE}/FFXIFullSetup_${REGION:upper}/PlayOnline/PlayOnlineViewer.msi" },
        { "file_exists": "${CACHE}/FFXIFullSetup_${REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi" }
      ] } },
      "verify_paths": [
        "${CACHE}/FFXIFullSetup_${REGION:upper}/PlayOnline/PlayOnlineViewer.msi",
        "${CACHE}/FFXIFullSetup_${REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi"
      ]
    },
    {
      "type": "wineexec",
      "description": "Install PlayOnline",
      "command": "msiexec",
      "args": ["-q", "-i", "${CACHE}/FFXIFullSetup_${REGION:upper}/PlayOnline/PlayOnlineViewer.msi"],
      "working_dir": "${CACHE}",
      "when": { "not": { "file_exists": "${PREFIX}/drive_c/Program Files (x86)/PlayOnline/SquareEnix/PlayOnlineViewer/pol.exe" } },
      "verify_paths": ["${PREFIX}/drive_c/Program Files (x86)/PlayOnline/SquareEnix/PlayOnlineViewer"]
    },
    {
      "type": "wineexec",
      "description": "Install Final Fantasy XI",
      "command": "msiexec",
      "args": ["-q", "-i", "${CACHE}/FFXIFullSetup_${REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi"],
      "working_dir": "${CACHE}",
      "when": { "not": { "file_exists": "${PREFIX}/drive_c/Program Files (x86)/PlayOnline/SquareEnix/FINAL FANTASY XI" } },
      "verify_paths": ["${PREFIX}/drive_c/Program Files (x86)/PlayOnline/SquareEnix/FINAL FANTASY XI"]
    },
    {
      "type": "write",
      "description": "lumoria_fix_missing_my_games_files.bat",
      "dst": "${CACHE}/lumoria_fix_missing_my_games_files.bat",
      "content": [
        "@echo off",
        "mkdir \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\" 2>nul",
        "mkdir \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\screenshots\" 2>nul",
        "type nul > \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\\prohibited.txt\"",
        "type nul > \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\\allowed.txt\""
      ],
      "when": { "not": { "any": [
        { "file_exists": "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt" },
        { "file_exists": "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt" }
      ] } },
      "verify_paths": ["${CACHE}/lumoria_fix_missing_my_games_files.bat"]
    },
    {
      "type": "wineexec",
      "description": "Run lumoria_fix_missing_my_games_files.bat",
      "command": "cmd.exe",
      "args": ["/C", "${CACHE}/lumoria_fix_missing_my_games_files.bat"],
      "when": { "not": { "any": [
        { "file_exists": "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt" },
        { "file_exists": "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt" }
      ] } },
      "verify_paths": [
        "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt",
        "${WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt"
      ]
    },
    {
      "type": "delete",
      "description": "Remove staged lumoria_fix_missing_my_games_files.bat",
      "dst": "${CACHE}/lumoria_fix_missing_my_games_files.bat"
    }
  ],
  "downloads": [
    {
      "id": "installer_part1",
      "url": "https://gdl.square-enix.com/ffxi/download/${REGION}/FFXIFullSetup_${REGION:upper}.part1.exe",
