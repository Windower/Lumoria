{
  "id": "ffxi",
  "name": "Final Fantasy XI",
  "version": "1.0",
  "variables": {
    "SE_DIR": {
      "default": "drive_c/Program Files (x86)/PlayOnline/SquareEnix",
      "rules": [
        {
          "value": "drive_c/Program Files/PlayOnline/SquareEnix",
          "when": {
            "var": {
              "ARCH": "win32"
            }
          }
        }
      ]
    },
    "WINE_USERPROFILE_HOST": "${winepath:%USERPROFILE%}",
    "REGION": "${prefix.region}"
  },
  "entrypoints": [
    {
      "id": "pol",
      "name": "PlayOnline Viewer",
      "exe": "${var.SE_DIR}/PlayOnlineViewer/pol.exe",
      "default": true
    },
    {
      "id": "pol-config",
      "name": "PlayOnline Config",
      "exe": "${var.SE_DIR}/PlayOnlineViewer/polcfg/polcfg.exe"
    },
    {
      "id": "ffxi-config",
      "name": "Final Fantasy XI Config",
      "exe": "${var.SE_DIR}/FINAL FANTASY XI/Tools${var.REGION:upper}/FINAL FANTASY XI Config.exe",
      "when": {
        "not": {
          "var": {
            "REGION": "jp"
          }
        }
      }
    },
    {
      "id": "ffxi-config",
      "name": "Final Fantasy XI Config",
      "exe": "${var.SE_DIR}/FINAL FANTASY XI/Tools/FINAL FANTASY XI Config.exe",
      "when": {
        "var": {
          "REGION": "jp"
        }
      }
    },
    {
      "id": "ffxi-padconfig",
      "name": "FFXI Gamepad Config",
      "exe": "${var.SE_DIR}/FINAL FANTASY XI/Tools${var.REGION:upper}/FFXiPadConfig.exe",
      "when": {
        "not": {
          "var": {
            "REGION": "jp"
          }
        }
      }
    },
    {
      "id": "ffxi-padconfig",
      "name": "FFXI Gamepad Config",
      "exe": "${var.SE_DIR}/FINAL FANTASY XI/Tools/FFXiPadConfig.exe",
      "when": {
        "var": {
          "REGION": "jp"
        }
      }
    }
  ],
  "redists": [
    "corefonts",
    "gdiplus"
  ],
  "env": [
    {
      "vars": {
        "LANG": "ja_JP.UTF-8"
      },
      "when": {
        "var": {
          "REGION": "jp"
        }
      }
    }
  ],
  "steps": [
    {
      "type": "dll_override",
      "description": "Disable mscoree when .NET is not installed",
      "command": "mscoree",
      "mode": "disabled",
      "when": {
        "not": {
          "any": [
            {
              "var": {
                "REDIST_dotnet48": "1"
              }
            },
            {
              "var": {
                "WINEBOOT_MSCOREE": "default"
              }
            }
          ]
        }
      }
    },
    {
      "type": "link",
      "description": "Prepare installer archive links",
      "mode": "symlink",
      "dst": "${var.CACHE}",
      "args": [
        "${var.CACHE}/installer_part1/FFXIFullSetup_${var.REGION:upper}.part1.exe",
        "${var.CACHE}/installer_part2/FFXIFullSetup_${var.REGION:upper}.part2.rar",
        "${var.CACHE}/installer_part3/FFXIFullSetup_${var.REGION:upper}.part3.rar",
        "${var.CACHE}/installer_part4/FFXIFullSetup_${var.REGION:upper}.part4.rar",
        "${var.CACHE}/installer_part5/FFXIFullSetup_${var.REGION:upper}.part5.rar"
      ]
    },
    {
      "type": "extract_multi",
      "description": "Extract installer archive",
      "src": "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}.part1.exe",
      "args": [
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}.part2.rar",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}.part3.rar",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}.part4.rar",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}.part5.rar"
      ],
      "dst": "${var.CACHE}",
      "when": {
        "not": {
          "any": [
            {
              "file_exists": "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/PlayOnline/PlayOnlineViewer.msi"
            },
            {
              "file_exists": "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi"
            }
          ]
        }
      },
      "verify_paths": [
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/PlayOnline/PlayOnlineViewer.msi",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi"
      ]
    },
    {
      "type": "wineexec",
      "description": "Install PlayOnline",
      "command": "msiexec",
      "args": [
        "-q",
        "-i",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/PlayOnline/PlayOnlineViewer.msi"
      ],
      "working_dir": "${var.CACHE}",
      "when": {
        "not": {
          "file_exists": "${var.PREFIX}/${var.SE_DIR}/PlayOnlineViewer/pol.exe"
        }
      },
      "verify_paths": [
        "${var.PREFIX}/${var.SE_DIR}/PlayOnlineViewer"
      ]
    },
    {
      "type": "wineexec",
      "description": "Install Final Fantasy XI",
      "command": "msiexec",
      "args": [
        "-q",
        "-i",
        "${var.CACHE}/FFXIFullSetup_${var.REGION:upper}/FINAL_FANTASY_XI/FINAL_FANTASY_XI.msi"
      ],
      "working_dir": "${var.CACHE}",
      "when": {
        "not": {
          "file_exists": "${var.PREFIX}/${var.SE_DIR}/FINAL FANTASY XI"
        }
      },
      "verify_paths": [
        "${var.PREFIX}/${var.SE_DIR}/FINAL FANTASY XI"
      ]
    },
    {
      "type": "write",
      "description": "lumoria_fix_missing_my_games_files.bat",
      "dst": "${var.CACHE}/lumoria_fix_missing_my_games_files.bat",
      "content": [
        "@echo off",
        "mkdir \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\" 2>nul",
        "mkdir \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\screenshots\" 2>nul",
        "type nul > \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\\prohibited.txt\"",
        "type nul > \"%USERPROFILE%\\Documents\\My Games\\FINAL FANTASY XI\\ffxiuser\\allowed.txt\""
      ],
      "when": {
        "not": {
          "any": [
            {
              "file_exists": "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt"
            },
            {
              "file_exists": "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt"
            }
          ]
        }
      },
      "verify_paths": [
        "${var.CACHE}/lumoria_fix_missing_my_games_files.bat"
      ]
    },
    {
      "type": "wineexec",
      "description": "Run lumoria_fix_missing_my_games_files.bat",
      "command": "cmd.exe",
      "args": [
        "/C",
        "${var.CACHE}/lumoria_fix_missing_my_games_files.bat"
      ],
      "when": {
        "not": {
          "any": [
            {
              "file_exists": "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt"
            },
            {
              "file_exists": "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt"
            }
          ]
        }
      },
      "verify_paths": [
        "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/allowed.txt",
        "${var.WINE_USERPROFILE_HOST}/Documents/My Games/FINAL FANTASY XI/ffxiuser/prohibited.txt"
      ]
    },
    {
      "type": "delete",
      "description": "Remove staged lumoria_fix_missing_my_games_files.bat",
      "dst": "${var.CACHE}/lumoria_fix_missing_my_games_files.bat"
    }
  ],
  "downloads": [
    {
      "id": "installer_part1",
      "url": "https://gdl.square-enix.com/ffxi/download/${var.REGION}/FFXIFullSetup_${var.REGION:upper}.part1.exe",
      "dest": "${var.CACHE}/installer_part1/FFXIFullSetup_${var.REGION:upper}.part1.exe",
      "sha256": "8b7abd42aa7c3cc4378f1fa02e3ea1e6019d2041bc8b77931f03a3f8202ceec9",
