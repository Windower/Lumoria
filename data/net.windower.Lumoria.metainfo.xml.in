<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 Lumoria Contributors -->
<component type="desktop-application">
  <id>net.windower.Lumoria</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Lumoria</name>
  <summary>Play a classic MMORPG on Linux</summary>

  <description>
    <p>
      Lumoria is a native Linux installer and launcher for a classic MMORPG. Install the game,
      manage Wine prefixes, runners, and all the other stuff you need to get playing ...
      All from a single app!
    </p>
    <p>
      Supports DXVK, Windower 4, multiple game installations with
      independent configurations, gamepad navigation and more.
    </p>
  </description>

  <launchable type="desktop-id">net.windower.Lumoria.desktop</launchable>

  <url type="homepage">https://lumoria.windower.net/</url>
  <url type="bugtracker">https://github.com/Windower/Lumoria/issues</url>
  <url type="faq">https://github.com/Windower/Lumoria/wiki</url>
  <url type="vcs-browser">https://github.com/Windower/Lumoria</url>

  <developer id="net.windower">
    <name>Lumoria Contributors</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="dark">#472B57</color>
    <color type="primary" scheme_preference="light">#DFBCD7</color>
  </branding>

  <content_rating type="oars-1.1" />

  <requires>
      <display_length compare="ge">600</display_length>
      <control>pointing</control>
      <control>keyboard</control>
  </requires>
  
  <supports>
    <control>gamepad</control>
  </supports>

  <categories>
    <category>Game</category>
    <category>PackageManager</category>
  </categories>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Windower/Lumoria/refs/heads/main/assets/screenshots/4-prefix-setup.png</image>
      <caption>The main interface of Lumoria</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Windower/Lumoria/refs/heads/main/assets/screenshots/3-installation.png</image>
      <caption>Game Installation</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Windower/Lumoria/refs/heads/main/assets/screenshots/5-manage-prefix.png</image>
      <caption>Prefix Management</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.1.14" date="2026-05-17">
      <description>
        <ul>
          <li>Setup Prefix, Manage Prefix, and Preferences UX cleanup and improvements.</li>
          <li>Additional .NET and VC++ runtime versions supported.</li>
          <li>Fixes to gamepad navigation.</li>
          <li>Experimental support for Windower 5.</li>
          <li>Cleanup of installer JSON language variable handling.</li>
          <li>Fix Windower addon settings reverting to off.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.13" date="2026-05-15">
      <description>
        <ul>
          <li>Prelaunch Scripts broke with working directory changes</li>
        </ul>
      </description>
    </release>
    <release version="0.1.12" date="2026-05-14">
      <description>
        <ul>
          <li>Custom entries now use GUID for IDs.</li>
          <li>Hide 32-bit Wine runner variants by default in Flatpak builds.</li>
          <li>Further refinements to subreaper process management.</li>
          <li>Shortcuts can be removed if you already deleted the .desktop</li>
          <li>Custom Entry UI cleanup</li>
        </ul>
      </description>
    </release>
    <release version="0.1.11" date="2026-05-12">
      <description>
        <ul>
          <li>Fix icu library path issues for Proton runners.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.10" date="2026-05-10">
      <description>
        <ul>
          <li>New Wine runners for older hardware architectures.</li>
          <li>Set default wine runner to GE-Proton.</li>
          <li>Fixes to installation process so post install redists are installed correctly.</li>
          <li>Better UI/UX for version selection and management.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.9" date="2026-05-07">
      <description>
        <ul>
          <li>Select specific Wine runner version for each prefix at installation time.</li>
          <li>Support for disabling problematic Wine versions.</li>
        </ul>
      </description>
    </release>

    <release version="0.1.7" date="2026-05-03">
      <description>
        <ul>
          <li>Install other XI client regions: EU, JP.</li>
          <li>New redists: allfonts, vcrun2022.</li>
          <li>New Package Manager feature under Manage Prefix.</li>
          <li>Extensive updates to the manifest file system to support new custom install features.</li>
          <li>Preference to disable gamepad navigation.</li>
          <li>Experimental D7VK support for POL.</li>
        </ul>
      </description>
    </release>

    <release version="0.1.6" date="2026-04-29">
      <description>
        <ul>
          <li>Post Install Scripts support.</li>
          <li>Fix GDIPlus installation issues.</li>
          <li>Storage tab under Preferences for managing Lumoria's storage.</li>
          <li>New reaper to better capture child process output after Windower forks.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2026-03-29">
      <description>
        <ul>
          <li>Add support for gamepad navigation.</li>
          <li>Add support for prelaunch scripts.</li>
          <li>Add support for custom launch entries.</li>
          <li>Remove file browsing in gamescope sessions.</li>
          <li>UI refactored to be more controller friendly.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-01">
      <description>
        <p>Initial testing release of Lumoria.</p>
      </description>
    </release>
  </releases>

</component>
